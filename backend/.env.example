DATABASE_URL="postgresql://skillswap:skillswap@localhost:5432/skillswap?schema=public"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-refresh-me"
PORT=4000
NODE_ENV=development

# Set to "true" to skip JWT and impersonate seeded users (demo + admin API). Never use in production.
DISABLE_AUTH=true
# DEV_IMPERSONATE_EMAIL=demo@skillswap.local
# ADMIN_IMPERSONATE_EMAIL=admin@skillswap.local

# Optional overrides for prisma/seed.ts dummy accounts
# ADMIN_SEED_PASSWORD=admin123
# DEMO_USER_SEED_PASSWORD=user123
