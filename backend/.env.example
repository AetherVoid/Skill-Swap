# Prisma connects here. Use local Docker, or Supabase → Project Settings → Database → Connection string (URI).
# Supabase: use the "Transaction" or "Session" pooler URI for server apps; include ?sslmode=require if needed.
# Create tables: (1) paste prisma/supabase-init.sql in Supabase SQL Editor, or (2) set DATABASE_URL and run: npx prisma db push
DATABASE_URL="postgresql://skillswap:skillswap@localhost:5432/skillswap?schema=public"

# Optional — only if you use @supabase/supabase-js (Auth/Storage/Realtime). Not required for Prisma-only.
# SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# SUPABASE_ANON_KEY="your-publishable-or-anon-key"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-refresh-me"
PORT=4000
NODE_ENV=development

# Set to "true" to skip JWT and impersonate seeded users (demo + admin API). Never use in production.
DISABLE_AUTH=true
# DEV_IMPERSONATE_EMAIL=demo@skillswap.local
# ADMIN_IMPERSONATE_EMAIL=admin@skillswap.local

# Optional overrides for prisma/seed.ts dummy accounts
# ADMIN_SEED_PASSWORD=admin123
# DEMO_USER_SEED_PASSWORD=user123
